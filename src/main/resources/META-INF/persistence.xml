<?xml version="1.0" encoding="UTF-8"?>
<persistence version="2.2"
             xmlns="http://xmlns.jcp.org/xml/ns/persistence"
             xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance"
             xsi:schemaLocation="http://xmlns.jcp.org/xml/ns/persistence http://xmlns.jcp.org/xml/ns/persistence/persistence_2_2.xsd">

    <persistence-unit name="EduConectaJPA" transaction-type="RESOURCE_LOCAL">
        <provider>org.eclipse.persistence.jpa.PersistenceProvider</provider>

        <!-- Entidades del Modelo de Dominio EduConecta (declaración explícita
             requerida para que EclipseLink las registre en Tomcat/RESOURCE_LOCAL). -->
        <class>com.educonecta.educonecta.modelo.Entidades.Usuario</class>
        <class>com.educonecta.educonecta.modelo.Entidades.Familiar</class>
        <class>com.educonecta.educonecta.modelo.Entidades.Especialista</class>
        <class>com.educonecta.educonecta.modelo.Entidades.CredencialProfesional</class>
        <class>com.educonecta.educonecta.modelo.Entidades.PerfilMenor</class>
        <class>com.educonecta.educonecta.modelo.Entidades.HistorialAtencion</class>
        <class>com.educonecta.educonecta.modelo.Entidades.Cita</class>
        <class>com.educonecta.educonecta.modelo.Entidades.Calendario</class>
        <class>com.educonecta.educonecta.modelo.Entidades.Atencion</class>
        <exclude-unlisted-classes>false</exclude-unlisted-classes>

        <properties>
            <property name="jakarta.persistence.jdbc.url" value="jdbc:mysql://localhost:3306/educonecta"/>
            <property name="jakarta.persistence.jdbc.user" value="root"/>
            <property name="jakarta.persistence.jdbc.password" value=""/>
            <property name="jakarta.persistence.jdbc.driver" value="com.mysql.cj.jdbc.Driver"/>
            <property name="eclipselink.ddl-generation" value="create-tables" />
            <!-- property name="eclipselink.ddl-generation" value="drop-and-create-tables" /-->
<!--            <property name="eclipselink.ddl-generation" value="none" />-->
        </properties>


    </persistence-unit>
</persistence>